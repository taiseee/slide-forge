{
  "name": "slide-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-agent-first Marp slide creation toolkit: curated layout classes, quality verification loop, bundled agent skill",
  "scripts": {
    "build": "marp --theme-set theme/ --html",
    "check": "node scripts/check-overflow.mjs",
    "quality": "node scripts/check-quality.mjs",
    "export": "node scripts/export.mjs",
    "init": "node scripts/init.mjs",
    "preview": "marp --theme-set theme/ --html --server .",
    "regress:recipes": "node scripts/regress-recipes.mjs",
    "regress:recipes:full": "node scripts/regress-recipes.mjs --full",
    "regress:visual": "node scripts/regress-recipes.mjs --visual",
    "render-visual": "node scripts/render-visual.mjs",
    "test": "node --test tests/*.test.mjs",
    "webui": "vite build --config webui/vite.config.mjs && node webui/server.mjs"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.2.3",
    "@marp-team/marp-core": "^4.3.1",
    "@vitejs/plugin-react": "^4.5.0",
    "ajv": "^8.20.0",
    "express": "^4.21.2",
    "js-yaml": "^5.2.1",
    "lucide-static": "^1.24.0",
    "mermaid": "^11.16.0",
    "puppeteer": "^24.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "turndown": "^7.2.4",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "vite": "^6.3.5"
  }
}
